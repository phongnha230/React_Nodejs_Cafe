# Database Configuration
# Local: mysql://root:password@127.0.0.1:3307/coffeeshop
DB_URL=mysql://user:password@host:port/database

# Docker Database Configuration (Used by docker-compose)
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=coffeeshop

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Configuration (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Initial Admin Configuration (for scripts/createAdminSimple.js)
ADMIN_INIT_EMAIL=admin@yourdomain.com
ADMIN_INIT_PASSWORD=ChangeThisPassword123!
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Configuration
PORT=5000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional: Upload Directory (If not using Cloudinary)
# UPLOAD_DIR=./uploads
